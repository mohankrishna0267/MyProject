	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "1. Register User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Admin\",\n  \"email\": \"admin@agriserve.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"ADMIN\",\n  \"phone\": \"9876543210\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/auth/register",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["api", "auth", "register"]
						}
					}
				},
				{
					"name": "2. Login User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@agriserve.com\",\n  \"password\": \"SecurePass123!\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/auth/login",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["api", "auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Farmer Management",
			"item": [
				{
					"name": "1. Register Farmer",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Ramesh Kumar\",\n  \"dob\": \"1985-06-15\",\n  \"gender\": \"MALE\",\n  \"address\": \"Village 1, District 2\",\n  \"contactInfo\": \"9123456780\",\n  \"landSize\": 5.5,\n  \"cropType\": \"Wheat, Rice\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/farmers",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["api", "farmers"]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "jwt_token",
			"value": "YOUR_TOKEN_HERE"
		}
